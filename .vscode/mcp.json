{
	"servers": {
		"chroma-core/chroma-mcp": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"chroma-mcp@v0.2.6"
			],
			"env": {
				"CHROMA_CLIENT_TYPE": "${input:chroma_client_type}",
				"CHROMA_DOTENV_PATH": "${input:chroma_dotenv_path}",
				"CHROMA_DATA_DIR": "${input:chroma_data_dir}",
				"CHROMA_TENANT": "${input:chroma_tenant}",
				"CHROMA_DATABASE": "${input:chroma_database}",
				"CHROMA_API_KEY": "${input:chroma_api_key}",
				"CHROMA_HOST": "${input:chroma_host}",
				"CHROMA_PORT": "${input:chroma_port}",
				"CHROMA_CUSTOM_AUTH_CREDENTIALS": "${input:chroma_custom_auth}",
				"CHROMA_SSL": "${input:chroma_ssl}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"com.apify/apify-mcp-server": {
			"type": "http",
			"url": "https://mcp.apify.com/",
			"headers": {
				"Authorization": "${input:Authorization}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.9.16"
		},
		"io.github.getsentry/sentry-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sentry/mcp-server@0.25.0"
			],
			"env": {
				"SENTRY_ACCESS_TOKEN": "${input:SENTRY_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.25.0"
		},
		"io.github.mongodb-js/mongodb-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"mongodb-mcp-server@1.9.0",
				"--allowRequestOverrides",
				"${input:allowRequestOverrides}",
				"--apiClientId",
				"${input:apiClientId}",
				"--apiClientSecret",
				"${input:apiClientSecret}",
				"--assistantBaseUrl",
				"${input:assistantBaseUrl}",
				"--atlasTemporaryDatabaseUserLifetimeMs",
				"${input:atlasTemporaryDatabaseUserLifetimeMs}",
				"--confirmationRequiredTools",
				"${input:confirmationRequiredTools}",
				"--connectionString",
				"${input:connectionString}",
				"--disabledTools",
				"${input:disabledTools}",
				"--dryRun",
				"${input:dryRun}",
				"--exportCleanupIntervalMs",
				"${input:exportCleanupIntervalMs}",
				"--exportTimeoutMs",
				"${input:exportTimeoutMs}",
				"--exportsPath",
				"${input:exportsPath}",
				"--externallyManagedSessions",
				"${input:externallyManagedSessions}",
				"--healthCheckHost",
				"${input:healthCheckHost}",
				"--healthCheckPort",
				"${input:healthCheckPort}",
				"--httpBodyLimit",
				"${input:httpBodyLimit}",
				"--httpHeaders",
				"${input:httpHeaders}",
				"--httpHost",
				"${input:httpHost}",
				"--httpPort",
				"${input:httpPort}",
				"--httpResponseType",
				"${input:httpResponseType}",
				"--idleTimeoutMs",
				"${input:idleTimeoutMs}",
				"--indexCheck",
				"${input:indexCheck}",
				"--logPath",
				"${input:logPath}",
				"--loggers",
				"${input:loggers}",
				"--maxBytesPerQuery",
				"${input:maxBytesPerQuery}",
				"--maxDocumentsPerQuery",
				"${input:maxDocumentsPerQuery}",
				"--monitoringServerFeatures",
				"${input:monitoringServerFeatures}",
				"--monitoringServerHost",
				"${input:monitoringServerHost}",
				"--monitoringServerPort",
				"${input:monitoringServerPort}",
				"--notificationTimeoutMs",
				"${input:notificationTimeoutMs}",
				"--previewFeatures",
				"${input:previewFeatures}",
				"--readOnly",
				"${input:readOnly}",
				"--telemetry",
				"${input:telemetry}",
				"--transport",
				"${input:transport}",
				"--voyageApiKey",
				"${input:voyageApiKey}"
			],
			"env": {
				"MDB_MCP_ALLOW_REQUEST_OVERRIDES": "${input:MDB_MCP_ALLOW_REQUEST_OVERRIDES}",
				"MDB_MCP_API_CLIENT_ID": "${input:MDB_MCP_API_CLIENT_ID}",
				"MDB_MCP_API_CLIENT_SECRET": "${input:MDB_MCP_API_CLIENT_SECRET}",
				"MDB_MCP_ASSISTANT_BASE_URL": "${input:MDB_MCP_ASSISTANT_BASE_URL}",
				"MDB_MCP_ATLAS_TEMPORARY_DATABASE_USER_LIFETIME_MS": "${input:MDB_MCP_ATLAS_TEMPORARY_DATABASE_USER_LIFETIME_MS}",
				"MDB_MCP_CONFIRMATION_REQUIRED_TOOLS": "${input:MDB_MCP_CONFIRMATION_REQUIRED_TOOLS}",
				"MDB_MCP_CONNECTION_STRING": "${input:MDB_MCP_CONNECTION_STRING}",
				"MDB_MCP_DISABLED_TOOLS": "${input:MDB_MCP_DISABLED_TOOLS}",
				"MDB_MCP_DRY_RUN": "${input:MDB_MCP_DRY_RUN}",
				"MDB_MCP_EXPORT_CLEANUP_INTERVAL_MS": "${input:MDB_MCP_EXPORT_CLEANUP_INTERVAL_MS}",
				"MDB_MCP_EXPORT_TIMEOUT_MS": "${input:MDB_MCP_EXPORT_TIMEOUT_MS}",
				"MDB_MCP_EXPORTS_PATH": "${input:MDB_MCP_EXPORTS_PATH}",
				"MDB_MCP_EXTERNALLY_MANAGED_SESSIONS": "${input:MDB_MCP_EXTERNALLY_MANAGED_SESSIONS}",
				"MDB_MCP_HEALTH_CHECK_HOST": "${input:MDB_MCP_HEALTH_CHECK_HOST}",
				"MDB_MCP_HEALTH_CHECK_PORT": "${input:MDB_MCP_HEALTH_CHECK_PORT}",
				"MDB_MCP_HTTP_BODY_LIMIT": "${input:MDB_MCP_HTTP_BODY_LIMIT}",
				"MDB_MCP_HTTP_HEADERS": "${input:MDB_MCP_HTTP_HEADERS}",
				"MDB_MCP_HTTP_HOST": "${input:MDB_MCP_HTTP_HOST}",
				"MDB_MCP_HTTP_PORT": "${input:MDB_MCP_HTTP_PORT}",
				"MDB_MCP_HTTP_RESPONSE_TYPE": "${input:MDB_MCP_HTTP_RESPONSE_TYPE}",
				"MDB_MCP_IDLE_TIMEOUT_MS": "${input:MDB_MCP_IDLE_TIMEOUT_MS}",
				"MDB_MCP_INDEX_CHECK": "${input:MDB_MCP_INDEX_CHECK}",
				"MDB_MCP_LOG_PATH": "${input:MDB_MCP_LOG_PATH}",
				"MDB_MCP_LOGGERS": "${input:MDB_MCP_LOGGERS}",
				"MDB_MCP_MAX_BYTES_PER_QUERY": "${input:MDB_MCP_MAX_BYTES_PER_QUERY}",
				"MDB_MCP_MAX_DOCUMENTS_PER_QUERY": "${input:MDB_MCP_MAX_DOCUMENTS_PER_QUERY}",
				"MDB_MCP_MONITORING_SERVER_FEATURES": "${input:MDB_MCP_MONITORING_SERVER_FEATURES}",
				"MDB_MCP_MONITORING_SERVER_HOST": "${input:MDB_MCP_MONITORING_SERVER_HOST}",
				"MDB_MCP_MONITORING_SERVER_PORT": "${input:MDB_MCP_MONITORING_SERVER_PORT}",
				"MDB_MCP_NOTIFICATION_TIMEOUT_MS": "${input:MDB_MCP_NOTIFICATION_TIMEOUT_MS}",
				"MDB_MCP_PREVIEW_FEATURES": "${input:MDB_MCP_PREVIEW_FEATURES}",
				"MDB_MCP_READ_ONLY": "${input:MDB_MCP_READ_ONLY}",
				"MDB_MCP_TELEMETRY": "${input:MDB_MCP_TELEMETRY}",
				"MDB_MCP_TRANSPORT": "${input:MDB_MCP_TRANSPORT}",
				"MDB_MCP_VOYAGE_API_KEY": "${input:MDB_MCP_VOYAGE_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.9.0"
		},
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@upstash/context7-mcp@1.0.31"
			],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.31"
		},
		"io.github.wonderwhy-er/desktop-commander": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"@wonderwhy-er/desktop-commander@0.2.38"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.38"
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"oraios/serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"serena@latest",
				"--context",
				"ide-assistant"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"firecrawl/firecrawl-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"firecrawl-mcp@latest"
			],
			"env": {
				"FIRECRAWL_API_KEY": "${input:api_key}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"com.microsoft/azure": {
			"type": "stdio",
			"command": "dnx",
			"args": [
				"Azure.Mcp@3.0.0-beta.1",
				"--yes",
				"--",
				"server",
				"start"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "3.0.0-beta.1"
		},
		"com.supabase/mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--project-ref",
				"${input:project-ref}",
				"--read-only",
				"${input:read-only}",
				"--features",
				"${input:features}",
				"--api-url",
				"${input:api-url}",
				"--registry",
				"https://registry.npmjs.org",
				"@supabase/mcp-server-supabase@0.7.0"
			],
			"env": {
				"SUPABASE_ACCESS_TOKEN": "${input:SUPABASE_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.7.0"
		},
		"io.github.brightdata/brightdata-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"@brightdata/mcp@2.9.4"
			],
			"env": {
				"API_TOKEN": "${input:API_TOKEN}",
				"WEB_UNLOCKER_ZONE": "${input:WEB_UNLOCKER_ZONE}",
				"BROWSER_ZONE": "${input:BROWSER_ZONE}",
				"PRO_MODE": "${input:PRO_MODE}",
				"GROUPS": "${input:GROUPS}",
				"TOOLS": "${input:TOOLS}",
				"POLLING_TIMEOUT": "${input:POLLING_TIMEOUT}",
				"BASE_TIMEOUT": "${input:BASE_TIMEOUT}",
				"BASE_MAX_RETRIES": "${input:BASE_MAX_RETRIES}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "2.9.4"
		},
		"sunriseapps/imagesorcery-mcp": {
			"type": "stdio",
			"command": "other",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"azure-ai-foundry/mcp-foundry": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--prerelease=allow",
				"--from",
				"git+https://github.com/azure-ai-foundry/mcp-foundry.git",
				"run-azure-ai-foundry-mcp",
				"--envFile",
				"${input:env_file_path}"
			],
			"env": {
				"GITHUB_TOKEN": "${input:github_token}",
				"AZURE_AI_SEARCH_ENDPOINT": "${input:ai_search_endpoint}",
				"AZURE_AI_SEARCH_API_VERSION": "${input:ai_search_api_version}",
				"SEARCH_AUTHENTICATION_METHOD": "${input:search_auth_method}",
				"AZURE_TENANT_ID": "${input:azure_tenant_id}",
				"AZURE_CLIENT_ID": "${input:azure_client_id}",
				"AZURE_CLIENT_SECRET": "${input:azure_client_secret}",
				"AZURE_AI_SEARCH_API_KEY": "${input:ai_search_api_key}",
				"EVAL_DATA_DIR": "${input:eval_data_dir}",
				"AZURE_OPENAI_ENDPOINT": "${input:az_openai_endpoint}",
				"AZURE_OPENAI_API_KEY": "${input:az_openai_api_key}",
				"AZURE_OPENAI_DEPLOYMENT": "${input:az_openai_deployment}",
				"AZURE_OPENAI_API_VERSION": "${input:az_openai_api_version}",
				"AZURE_AI_PROJECT_ENDPOINT": "${input:ai_project_endpoint}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"octopusdeploy/mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@octopusdeploy/mcp-server@latest"
			],
			"env": {
				"OCTOPUS_API_KEY": "${input:octopus_api_key}",
				"OCTOPUS_SERVER_URL": "${input:octopus_server_url}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"io.github.dynatrace-oss/Dynatrace-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--registry",
				"https://registry.npmjs.org",
				"@dynatrace-oss/dynatrace-mcp-server@1.7.5"
			],
			"env": {
				"DT_ENVIRONMENT": "${input:DT_ENVIRONMENT}",
				"DT_PLATFORM_TOKEN": "${input:DT_PLATFORM_TOKEN}",
				"OAUTH_CLIENT_ID": "${input:OAUTH_CLIENT_ID}",
				"OAUTH_CLIENT_SECRET": "${input:OAUTH_CLIENT_SECRET}",
				"DT_GRAIL_QUERY_BUDGET_GB": "${input:DT_GRAIL_QUERY_BUDGET_GB}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.7.5"
		}
	},
	"inputs": [
		{
			"id": "chroma_client_type",
			"type": "promptString",
			"description": "Client type: ephemeral (default), persistent, cloud, or http.",
			"password": false
		},
		{
			"id": "chroma_dotenv_path",
			"type": "promptString",
			"description": "Optional path to .env (defaults to ./.chroma_env).",
			"password": false
		},
		{
			"id": "chroma_data_dir",
			"type": "promptString",
			"description": "Data directory for persistent client.",
			"password": false
		},
		{
			"id": "chroma_tenant",
			"type": "promptString",
			"description": "Chroma Cloud tenant ID.",
			"password": false
		},
		{
			"id": "chroma_database",
			"type": "promptString",
			"description": "Chroma Cloud database name.",
			"password": false
		},
		{
			"id": "chroma_api_key",
			"type": "promptString",
			"description": "Chroma Cloud API key.",
			"password": true
		},
		{
			"id": "chroma_host",
			"type": "promptString",
			"description": "Self-hosted Chroma host.",
			"password": false
		},
		{
			"id": "chroma_port",
			"type": "promptString",
			"description": "Self-hosted Chroma port.",
			"password": false
		},
		{
			"id": "chroma_custom_auth",
			"type": "promptString",
			"description": "Custom auth credentials for self-hosted Chroma.",
			"password": true
		},
		{
			"id": "chroma_ssl",
			"type": "promptString",
			"description": "Use SSL (true/false) for self-hosted HTTP.",
			"password": false
		},
		{
			"id": "Authorization",
			"type": "promptString",
			"description": "Apify API token for authentication with Apify platform services. For example 'Bearer <apify-api-token>'",
			"password": true
		},
		{
			"id": "DT_ENVIRONMENT",
			"type": "promptString",
			"description": "The URL of your Dynatrace environment (e.g. 'https://abc12345.apps.dynatrace.com'). Do not use Dynatrace classic URLs.",
			"password": false
		},
		{
			"id": "DT_PLATFORM_TOKEN",
			"type": "promptString",
			"description": "[OPTIONAL] Dynatrace Platform Token for authentication. Alternative to OAuth authentication.",
			"password": false
		},
		{
			"id": "OAUTH_CLIENT_ID",
			"type": "promptString",
			"description": "[OPTIONAL] OAuth Client ID for advanced authentication scenarios. Use with OAUTH_CLIENT_SECRET.",
			"password": false
		},
		{
			"id": "OAUTH_CLIENT_SECRET",
			"type": "promptString",
			"description": "[OPTIONAL] OAuth Client Secret for advanced authentication scenarios. Use with OAUTH_CLIENT_ID.",
			"password": false
		},
		{
			"id": "DT_GRAIL_QUERY_BUDGET_GB",
			"type": "promptString",
			"description": "[OPTIONAL] Budget limit in GB for Grail query bytes scanned per session. Default: 1000. Set to -1 to disable budget tracking.",
			"password": false
		},
		{
			"id": "SENTRY_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Your Sentry user authentication token",
			"password": true
		},
		{
			"id": "MDB_MCP_ALLOW_REQUEST_OVERRIDES",
			"type": "promptString",
			"description": "When set to true, allows configuration values to be overridden via request headers and query parameters.",
			"password": false
		},
		{
			"id": "MDB_MCP_API_CLIENT_ID",
			"type": "promptString",
			"description": "Atlas API client ID for authentication. Required for running Atlas tools.",
			"password": true
		},
		{
			"id": "MDB_MCP_API_CLIENT_SECRET",
			"type": "promptString",
			"description": "Atlas API client secret for authentication. Required for running Atlas tools.",
			"password": true
		},
		{
			"id": "MDB_MCP_ASSISTANT_BASE_URL",
			"type": "promptString",
			"description": "Base URL for the MongoDB Assistant API.",
			"password": false
		},
		{
			"id": "MDB_MCP_ATLAS_TEMPORARY_DATABASE_USER_LIFETIME_MS",
			"type": "promptString",
			"description": "Time in milliseconds that temporary database users created when connecting to MongoDB Atlas clusters will remain active before being automatically deleted.",
			"password": false
		},
		{
			"id": "MDB_MCP_CONFIRMATION_REQUIRED_TOOLS",
			"type": "promptString",
			"description": "Comma separated values of tool names that require user confirmation before execution. Requires the client to support elicitation.",
			"password": false
		},
		{
			"id": "MDB_MCP_CONNECTION_STRING",
			"type": "promptString",
			"description": "MongoDB connection string for direct database connections. Optional, if not set, you'll need to call the connect tool before interacting with MongoDB data.",
			"password": true
		},
		{
			"id": "MDB_MCP_DISABLED_TOOLS",
			"type": "promptString",
			"description": "Comma separated values of tool names, operation types, and/or categories of tools that will be disabled.",
			"password": false
		},
		{
			"id": "MDB_MCP_DRY_RUN",
			"type": "promptString",
			"description": "When true, runs the server in dry mode: dumps configuration and enabled tools, then exits without starting the server.",
			"password": false
		},
		{
			"id": "MDB_MCP_EXPORT_CLEANUP_INTERVAL_MS",
			"type": "promptString",
			"description": "Time in milliseconds between export cleanup cycles that remove expired export files.",
			"password": false
		},
		{
			"id": "MDB_MCP_EXPORT_TIMEOUT_MS",
			"type": "promptString",
			"description": "Time in milliseconds after which an export is considered expired and eligible for cleanup.",
			"password": false
		},
		{
			"id": "MDB_MCP_EXPORTS_PATH",
			"type": "promptString",
			"description": "Folder to store exported data files.",
			"password": false
		},
		{
			"id": "MDB_MCP_EXTERNALLY_MANAGED_SESSIONS",
			"type": "promptString",
			"description": "When true, the HTTP transport allows requests with a session ID supplied externally through the 'mcp-session-id' header. When an external ID is supplied, the initialization request is optional.",
			"password": false
		},
		{
			"id": "MDB_MCP_HEALTH_CHECK_HOST",
			"type": "promptString",
			"description": "Deprecated. Use `monitoringServerHost` instead. Host address to bind the healthCheck HTTP server to (only used when transport is 'http'). If provided, `healthCheckPort` must also be set.",
			"password": false
		},
		{
			"id": "MDB_MCP_HEALTH_CHECK_PORT",
			"type": "promptString",
			"description": "Deprecated. Use `monitoringServerPort` instead. Port number for the healthCheck HTTP server (only used when transport is 'http'). If provided, `healthCheckHost` must also be set.",
			"password": false
		},
		{
			"id": "MDB_MCP_HTTP_BODY_LIMIT",
			"type": "promptString",
			"description": "Maximum size of the HTTP request body in bytes (only used when transport is 'http'). This value is passed as the optional limit parameter to the Express.js json() middleware.",
			"password": false
		},
		{
			"id": "MDB_MCP_HTTP_HEADERS",
			"type": "promptString",
			"description": "Header that the HTTP server will validate when making requests (only used when transport is 'http').",
			"password": false
		},
		{
			"id": "MDB_MCP_HTTP_HOST",
			"type": "promptString",
			"description": "Host address to bind the HTTP server to (only used when transport is 'http').",
			"password": false
		},
		{
			"id": "MDB_MCP_HTTP_PORT",
			"type": "promptString",
			"description": "Port number for the HTTP server (only used when transport is 'http'). Use 0 for a random port.",
			"password": false
		},
		{
			"id": "MDB_MCP_HTTP_RESPONSE_TYPE",
			"type": "promptString",
			"description": "The HTTP response type for tool responses: 'sse' for Server-Sent Events, 'json' for standard JSON responses.",
			"password": false
		},
		{
			"id": "MDB_MCP_IDLE_TIMEOUT_MS",
			"type": "promptString",
			"description": "Idle timeout for a client to disconnect (only applies to http transport).",
			"password": false
